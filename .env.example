# XAI_API_KEY: Required for Grok API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
XAI_API_KEY="MY_XAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SITE_URL: Public canonical origin used for SEO metadata, robots, and sitemap.
# Defaults to APP_URL when omitted.
SITE_URL="https://compare-ai.com"

# ADMIN_PASSWORD: Required to log in to the private /admin dashboard.
ADMIN_PASSWORD="change-me"

# ADMIN_SESSION_SECRET: Secret used to sign admin session cookies.
# Use a long random string in production.
ADMIN_SESSION_SECRET="change-me-random-secret"

# ANALYTICS_DB_PATH: Optional path for the local SQLite analytics database.
# Defaults to server/compareai-analytics.db.
ANALYTICS_DB_PATH="server/compareai-analytics.db"

# VITE_X_SEARCH_MODE: Controls when the researcher can use X Search.
# auto: let Grok decide when recent X/social context is useful.
# off: never include X Search.
# always: ask Grok to include recent X discussion.
VITE_X_SEARCH_MODE="auto"
