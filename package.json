{
  "name": "compare-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --port=5173 --host=0.0.0.0\"",
    "dev:server": "tsx server/index.ts",
    "dev:client": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "test": "tsx --test tests/server/*.test.ts tests/services/*.test.ts tests/seo/*.test.ts",
    "test:real": "RUN_REAL_API_TESTS=1 tsx --test tests/server/*.real.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gsap": "^3.14.2",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.18",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ogl": "^1.0.11",
    "openai": "^4.77.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "recharts": "^3.8.0",
    "satori": "^0.26.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
